---
interface Props {
  quote: string;
  cite?: string;
}

const { quote, cite } = Astro.props;
---

<figure class="pullquote">
  <p class="pullquote__text">{quote}</p>
  {cite && <figcaption class="pullquote__cite">— {cite}</figcaption>}
</figure>

<style>
  .pullquote {
    margin-block: 2.5rem;
  }

  .pullquote__text {
    font-family: 'Fraunces Variable', serif;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.3;
    color: #191d24;
    border-left: 4px solid #ffe6c9;
    padding-left: 1.5rem;
  }

  .pullquote__cite {
    margin-top: 0.75rem;
    padding-left: 1.5rem;
    font-size: 0.875rem;
    color: rgba(25, 29, 36, 0.5);
  }

  @media (min-width: 640px) {
    .pullquote__text {
      font-size: 2rem;
    }
  }
</style>
